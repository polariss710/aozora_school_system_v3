NODE_ENV=development
PORT=3000
JWT_SECRET="replace-with-a-long-random-secret"
CORS_ORIGIN="http://localhost:5173,https://aozora-school-system-v3-demo.onrender.com"
OPERATIONAL_BUSINESS_ENTITY_CODE="aozora_school"

# Runtime connection. Use the Supabase session/transaction pooler URL.
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:5432/postgres"

# Migration/introspection connection. Use the Supabase direct connection URL when available.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@DIRECT_HOST:5432/postgres"

# Optional seed-only admin user. If both email and password are set, `pnpm --dir apps/api db:seed`
# will upsert the admin user and assign the `admin` role.
V3_ADMIN_EMAIL=""
V3_ADMIN_PASSWORD=""
V3_ADMIN_DISPLAY_NAME="系统管理员"
