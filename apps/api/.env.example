NODE_ENV=development
PORT=3000
JWT_SECRET="replace-with-a-long-random-secret"
CORS_ORIGIN="http://localhost:5173,https://aozora-school-system-v3-demo.onrender.com"
OPERATIONAL_BUSINESS_ENTITY_CODE="aozora_school"
SCHOOL_RUNTIME_ENV="dev"

# Cash integration. Dev defaults to mock when CASH_INTEGRATION_MODE is omitted.
# Use supabase only with the Cash project that belongs to the same environment.
CASH_INTEGRATION_MODE="mock"
CASH_DEV_SUPABASE_URL=""
CASH_DEV_SERVICE_ROLE_KEY=""
CASH_DEV_USER_ID=""

# Staging Cash integration. These values must belong to the same v3-staging
# Supabase project used by DATABASE_URL / DIRECT_DATABASE_URL.
CASH_STAGING_SUPABASE_URL=""
CASH_STAGING_SERVICE_ROLE_KEY=""
CASH_STAGING_USER_ID=""

# Required outside dev. The API refuses to start when the Cash URL or database
# connections do not contain this exact project ref. Comma-separated forbidden
# values provide an additional guard against known dev/prod identities.
SCHOOL_ENVIRONMENT_PROJECT_REF=""
SCHOOL_FORBIDDEN_PROJECT_REFS=""
SCHOOL_FORBIDDEN_CASH_USER_IDS=""
SCHOOL_FORBIDDEN_ORIGIN_MARKERS=""

# Runtime connection. Use the Supabase session/transaction pooler URL.
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:5432/postgres"

# Migration/introspection connection. Use the Supabase direct connection URL when available.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@DIRECT_HOST:5432/postgres"

# Optional seed-only admin user. If both email and password are set, `pnpm --dir apps/api db:seed`
# will upsert the admin user and assign the `admin` role.
V3_ADMIN_EMAIL=""
V3_ADMIN_PASSWORD=""
V3_ADMIN_DISPLAY_NAME="系统管理员"
