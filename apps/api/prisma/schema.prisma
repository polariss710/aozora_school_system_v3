generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RecordStatus {
  active
  inactive
  archived
}

enum UserStatus {
  active
  suspended
  inactive
}

enum AccountType {
  corporate
  advance
}

enum CurrencyCode {
  JPY
  CNY
}

enum AuditRiskLevel {
  low
  medium
  high
  critical
}

enum PlannedLessonStatus {
  scheduled
  actual_created
  makeup_pending
  makeup_completed
  cancelled
}

enum ActualLessonStatus {
  completed
  cancelled
}

enum TuitionBillStatus {
  generated
  income_created
  voided
}

enum IncomeRecordStatus {
  pending
  voided
  cash_confirmed
}

enum ExpenseRecordStatus {
  pending
  voided
  cash_confirmed
}

enum CashRequestStatus {
  not_requested
  cash_requested
  cash_rejected
  cash_confirmed
  account_transaction_created
  needs_manual_review
}

enum CashRequestDirection {
  income
  expense
}

enum AccountTransactionDirection {
  in
  out
}

enum AccountTransactionStatus {
  active
  reversed
}

enum ExternalWorkLessonType {
  planned
  actual
}

enum ExternalWorkLessonStatus {
  scheduled
  actual_created
  completed
  cancelled
}

enum ExternalWorkSettlementStatus {
  locked
  income_created
  revoked
}

enum StudentSettlementStatus {
  locked
  revoked
}

enum TeacherWageSnapshotStatus {
  locked
  adjustment_confirmed
  expense_created
  revoked
}

enum TeacherWageAdjustmentStatus {
  none
  exported
  imported
  manual_adjusted
  confirmed
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  displayName  String     @map("display_name")
  status       UserStatus @default(active)
  passwordHash String?    @map("password_hash")
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz(6)
  memo         String?
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  userRoles   UserRole[]
  auditEvents AuditEvent[] @relation("AuditActor")

  @@index([status])
  @@map("users")
}

model Role {
  id          String       @id @default(uuid()) @db.Uuid
  code        String       @unique
  name        String
  description String?
  status      RecordStatus @default(active)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([status])
  @@map("roles")
}

model Permission {
  id          String       @id @default(uuid()) @db.Uuid
  code        String       @unique
  name        String
  description String?
  status      RecordStatus @default(active)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@index([status])
  @@map("permissions")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model BusinessEntity {
  id        String       @id @default(uuid()) @db.Uuid
  code      String       @unique
  name      String
  status    RecordStatus @default(active)
  memo      String?
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  students       Student[]
  plannedLessons StudentPlannedLesson[]
  actualLessons  StudentActualLesson[]
  incomeRecords  IncomeRecord[]
  expenseRecords ExpenseRecord[]
  wageRules      TeacherWageRule[]
  wageSnapshots  TeacherWageSnapshot[]

  @@index([status])
  @@map("business_entities")
}

model Account {
  id        String       @id @default(uuid()) @db.Uuid
  code      String       @unique
  name      String
  type      AccountType
  currency  CurrencyCode
  status    RecordStatus @default(active)
  memo      String?
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  transactions AccountTransaction[]

  @@index([status])
  @@index([type])
  @@map("accounts")
}

model AccountTransaction {
  id              String                      @id @default(uuid()) @db.Uuid
  accountId       String                      @map("account_id") @db.Uuid
  direction       AccountTransactionDirection
  sourceType      String                      @map("source_type")
  sourceId        String?                     @map("source_id")
  incomeRecordId  String?                     @map("income_record_id") @db.Uuid
  expenseRecordId String?                     @map("expense_record_id") @db.Uuid
  transactionDate DateTime                    @map("transaction_date") @db.Date
  title           String
  currency        CurrencyCode
  amountJpy       Int?                        @map("amount_jpy")
  amountCny       Decimal?                    @map("amount_cny") @db.Decimal(12, 2)
  status          AccountTransactionStatus    @default(active)
  idempotencyKey  String?                     @unique @map("idempotency_key")
  externalEventId String?                     @map("external_event_id")
  memo            String?
  reversedAt      DateTime?                   @map("reversed_at") @db.Timestamptz(6)
  createdAt       DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)

  account       Account        @relation(fields: [accountId], references: [id], onDelete: Restrict)
  incomeRecord  IncomeRecord?  @relation(fields: [incomeRecordId], references: [id], onDelete: Restrict)
  expenseRecord ExpenseRecord? @relation(fields: [expenseRecordId], references: [id], onDelete: Restrict)

  @@index([accountId, transactionDate])
  @@index([direction])
  @@index([sourceType, sourceId])
  @@index([incomeRecordId])
  @@index([expenseRecordId])
  @@index([status])
  @@map("account_transactions")
}

model Student {
  id                      String       @id @default(uuid()) @db.Uuid
  code                    String?      @unique
  name                    String
  kanaName                String?      @map("kana_name")
  status                  RecordStatus @default(active)
  primaryBusinessEntityId String?      @map("primary_business_entity_id") @db.Uuid
  memo                    String?
  legacyTable             String?      @map("legacy_table")
  legacyId                String?      @map("legacy_id")
  createdAt               DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  primaryBusinessEntity BusinessEntity?            @relation(fields: [primaryBusinessEntityId], references: [id], onDelete: Restrict)
  plannedLessons        StudentPlannedLesson[]
  actualLessons         StudentActualLesson[]
  tuitionBills          StudentTuitionBill[]
  monthlySettlements    StudentMonthlySettlement[]
  incomeRecords         IncomeRecord[]

  @@index([status])
  @@index([primaryBusinessEntityId])
  @@map("students")
}

model Teacher {
  id          String       @id @default(uuid()) @db.Uuid
  code        String?      @unique
  name        String
  kanaName    String?      @map("kana_name")
  status      RecordStatus @default(active)
  memo        String?
  legacyTable String?      @map("legacy_table")
  legacyId    String?      @map("legacy_id")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  plannedLessons StudentPlannedLesson[]
  actualLessons  StudentActualLesson[]
  wageRules      TeacherWageRule[]
  wageSnapshots  TeacherWageSnapshot[]
  expenseRecords ExpenseRecord[]

  @@index([status])
  @@map("teachers")
}

model Subject {
  id        String       @id @default(uuid()) @db.Uuid
  code      String       @unique
  name      String
  category  String?
  sortOrder Int          @default(0) @map("sort_order")
  status    RecordStatus @default(active)
  memo      String?
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  plannedLessons StudentPlannedLesson[]
  actualLessons  StudentActualLesson[]

  @@index([status])
  @@index([sortOrder])
  @@map("subjects")
}

model StudentPlannedLesson {
  id               String              @id @default(uuid()) @db.Uuid
  studentId        String              @map("student_id") @db.Uuid
  teacherId        String              @map("teacher_id") @db.Uuid
  subjectId        String              @map("subject_id") @db.Uuid
  businessEntityId String              @map("business_entity_id") @db.Uuid
  yearMonth        String              @map("year_month") @db.VarChar(7)
  weekAnchorDate   DateTime            @map("week_anchor_date") @db.Date
  lessonNo         Int?                @map("lesson_no")
  plannedStartTime String?             @map("planned_start_time") @db.VarChar(5)
  plannedEndTime   String?             @map("planned_end_time") @db.VarChar(5)
  durationHours    Decimal             @map("duration_hours") @db.Decimal(6, 2)
  plannedFeeJpy    Int                 @map("planned_fee_jpy")
  content          String?
  memo             String?
  status           PlannedLessonStatus @default(scheduled)
  sourceType       String              @default("manual") @map("source_type")
  sourceId         String?             @map("source_id")
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  student        Student              @relation(fields: [studentId], references: [id], onDelete: Restrict)
  teacher        Teacher              @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  subject        Subject              @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  businessEntity BusinessEntity       @relation(fields: [businessEntityId], references: [id], onDelete: Restrict)
  actualLesson   StudentActualLesson?

  @@index([yearMonth])
  @@index([studentId, yearMonth])
  @@index([teacherId, yearMonth])
  @@index([subjectId])
  @@index([businessEntityId])
  @@index([status])
  @@index([weekAnchorDate])
  @@map("student_planned_lessons")
}

model StudentActualLesson {
  id                  String             @id @default(uuid()) @db.Uuid
  plannedLessonId     String?            @unique @map("planned_lesson_id") @db.Uuid
  studentId           String             @map("student_id") @db.Uuid
  teacherId           String             @map("teacher_id") @db.Uuid
  subjectId           String             @map("subject_id") @db.Uuid
  businessEntityId    String             @map("business_entity_id") @db.Uuid
  yearMonth           String             @map("year_month") @db.VarChar(7)
  actualDate          DateTime           @map("actual_date") @db.Date
  startTime           String?            @map("start_time") @db.VarChar(5)
  endTime             String?            @map("end_time") @db.VarChar(5)
  durationHours       Decimal            @map("duration_hours") @db.Decimal(6, 2)
  content             String?
  memo                String?
  status              ActualLessonStatus @default(completed)
  teacherWageEligible Boolean            @default(true) @map("teacher_wage_eligible")
  sourceType          String             @default("planned_lesson") @map("source_type")
  sourceId            String?            @map("source_id")
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  plannedLesson  StudentPlannedLesson?       @relation(fields: [plannedLessonId], references: [id], onDelete: Restrict)
  student        Student                     @relation(fields: [studentId], references: [id], onDelete: Restrict)
  teacher        Teacher                     @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  subject        Subject                     @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  businessEntity BusinessEntity              @relation(fields: [businessEntityId], references: [id], onDelete: Restrict)
  wageDetails    TeacherWageSnapshotDetail[]

  @@index([yearMonth])
  @@index([studentId, yearMonth])
  @@index([teacherId, yearMonth])
  @@index([subjectId])
  @@index([businessEntityId])
  @@index([status])
  @@index([actualDate])
  @@map("student_actual_lessons")
}

model StudentTuitionBill {
  id                  String            @id @default(uuid()) @db.Uuid
  studentId           String            @map("student_id") @db.Uuid
  yearMonth           String            @map("year_month") @db.VarChar(7)
  plannedLessonCount  Int               @map("planned_lesson_count")
  plannedAmountJpy    Int               @map("planned_amount_jpy")
  carryoverAmountCny  Decimal           @default(0) @map("carryover_amount_cny") @db.Decimal(12, 2)
  status              TuitionBillStatus @default(generated)
  calculationSnapshot Json              @map("calculation_snapshot")
  incomeRecordId      String?           @unique @map("income_record_id") @db.Uuid
  generatedAt         DateTime          @default(now()) @map("generated_at") @db.Timestamptz(6)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  student      Student       @relation(fields: [studentId], references: [id], onDelete: Restrict)
  incomeRecord IncomeRecord? @relation(fields: [incomeRecordId], references: [id], onDelete: Restrict)

  @@unique([studentId, yearMonth])
  @@index([yearMonth])
  @@index([status])
  @@map("student_tuition_bills")
}

model StudentMonthlySettlement {
  id                         String                  @id @default(uuid()) @db.Uuid
  studentId                  String                  @map("student_id") @db.Uuid
  yearMonth                  String                  @map("year_month") @db.VarChar(7)
  plannedLessonCount         Int                     @map("planned_lesson_count")
  billableLessonCount        Int                     @map("billable_lesson_count")
  cancelledLessonCount       Int                     @map("cancelled_lesson_count")
  actualLessonCount          Int                     @map("actual_lesson_count")
  plannedAmountJpy           Int                     @map("planned_amount_jpy")
  billableAmountJpy          Int                     @map("billable_amount_jpy")
  receivedAmountJpy          Int                     @default(0) @map("received_amount_jpy")
  receivedAmountCny          Decimal                 @default(0) @map("received_amount_cny") @db.Decimal(12, 2)
  previousCarryoverAmountCny Decimal                 @default(0) @map("previous_carryover_amount_cny") @db.Decimal(12, 2)
  settlementExchangeRate     Decimal?                @map("settlement_exchange_rate") @db.Decimal(18, 8)
  adjustmentAmountCny        Decimal                 @default(0) @map("adjustment_amount_cny") @db.Decimal(12, 2)
  carryoverAmountCny         Decimal                 @default(0) @map("carryover_amount_cny") @db.Decimal(12, 2)
  status                     StudentSettlementStatus @default(locked)
  calculationSnapshot        Json                    @map("calculation_snapshot")
  lockedAt                   DateTime                @default(now()) @map("locked_at") @db.Timestamptz(6)
  revokedAt                  DateTime?               @map("revoked_at") @db.Timestamptz(6)
  memo                       String?
  createdAt                  DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  student Student @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@unique([studentId, yearMonth])
  @@index([yearMonth])
  @@index([status])
  @@map("student_monthly_settlements")
}

model TeacherWageRule {
  id               String       @id @default(uuid()) @db.Uuid
  teacherId        String       @map("teacher_id") @db.Uuid
  businessEntityId String       @map("business_entity_id") @db.Uuid
  hourlyRateJpy    Int          @map("hourly_rate_jpy")
  status           RecordStatus @default(active)
  memo             String?
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  teacher        Teacher        @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  businessEntity BusinessEntity @relation(fields: [businessEntityId], references: [id], onDelete: Restrict)

  @@unique([teacherId, businessEntityId])
  @@index([teacherId])
  @@index([businessEntityId])
  @@index([status])
  @@map("teacher_wage_rules")
}

model TeacherWageSnapshot {
  id                   String                      @id @default(uuid()) @db.Uuid
  teacherId            String                      @map("teacher_id") @db.Uuid
  yearMonth            String                      @map("year_month") @db.VarChar(7)
  businessEntityId     String                      @map("business_entity_id") @db.Uuid
  lessonCount          Int                         @map("lesson_count")
  totalLessonHours     Decimal                     @map("total_lesson_hours") @db.Decimal(8, 2)
  baseWageJpy          Int                         @map("base_wage_jpy")
  transportationFeeJpy Int                         @default(0) @map("transportation_fee_jpy")
  classroomFeeJpy      Int                         @default(0) @map("classroom_fee_jpy")
  manualAdjustmentJpy  Int                         @default(0) @map("manual_adjustment_jpy")
  totalWageJpy         Int                         @map("total_wage_jpy")
  status               TeacherWageSnapshotStatus   @default(locked)
  adjustmentStatus     TeacherWageAdjustmentStatus @default(none) @map("adjustment_status")
  calculationSnapshot  Json                        @map("calculation_snapshot")
  expenseRecordId      String?                     @unique @map("expense_record_id") @db.Uuid
  lockedAt             DateTime                    @default(now()) @map("locked_at") @db.Timestamptz(6)
  revokedAt            DateTime?                   @map("revoked_at") @db.Timestamptz(6)
  memo                 String?
  createdAt            DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)

  teacher        Teacher                     @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  businessEntity BusinessEntity              @relation(fields: [businessEntityId], references: [id], onDelete: Restrict)
  expenseRecord  ExpenseRecord?              @relation("TeacherWageExpense", fields: [expenseRecordId], references: [id], onDelete: Restrict)
  details        TeacherWageSnapshotDetail[]

  @@unique([teacherId, yearMonth, businessEntityId])
  @@index([yearMonth])
  @@index([teacherId, yearMonth])
  @@index([businessEntityId])
  @@index([status])
  @@index([adjustmentStatus])
  @@map("teacher_wage_snapshots")
}

model TeacherWageSnapshotDetail {
  id                  String   @id @default(uuid()) @db.Uuid
  snapshotId          String   @map("snapshot_id") @db.Uuid
  actualLessonId      String   @map("actual_lesson_id") @db.Uuid
  actualDate          DateTime @map("actual_date") @db.Date
  durationHours       Decimal  @map("duration_hours") @db.Decimal(6, 2)
  hourlyRateJpy       Int      @map("hourly_rate_jpy")
  lessonWageJpy       Int      @map("lesson_wage_jpy")
  teacherWageEligible Boolean  @map("teacher_wage_eligible")
  includedInWage      Boolean  @default(true) @map("included_in_wage")
  studentNameSnapshot String?  @map("student_name_snapshot")
  subjectNameSnapshot String?  @map("subject_name_snapshot")
  contentSnapshot     String?  @map("content_snapshot")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  snapshot     TeacherWageSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Restrict)
  actualLesson StudentActualLesson @relation(fields: [actualLessonId], references: [id], onDelete: Restrict)

  @@unique([snapshotId, actualLessonId])
  @@index([actualLessonId])
  @@map("teacher_wage_snapshot_details")
}

model IncomeRecord {
  id                 String             @id @default(uuid()) @db.Uuid
  sourceType         String             @map("source_type")
  sourceId           String?            @map("source_id")
  studentId          String?            @map("student_id") @db.Uuid
  businessEntityId   String?            @map("business_entity_id") @db.Uuid
  yearMonth          String?            @map("year_month") @db.VarChar(7)
  title              String
  originalCurrency   CurrencyCode       @map("original_currency")
  originalAmountJpy  Int?               @map("original_amount_jpy")
  originalAmountCny  Decimal?           @map("original_amount_cny") @db.Decimal(12, 2)
  carryoverAmountCny Decimal?           @map("carryover_amount_cny") @db.Decimal(12, 2)
  recordStatus       IncomeRecordStatus @default(pending) @map("record_status")
  cashStatus         CashRequestStatus  @default(not_requested) @map("cash_status")
  memo               String?
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  student                Student?                       @relation(fields: [studentId], references: [id], onDelete: Restrict)
  businessEntity         BusinessEntity?                @relation(fields: [businessEntityId], references: [id], onDelete: Restrict)
  tuitionBill            StudentTuitionBill?
  externalWorkSettlement ExternalWorkMonthlySettlement?
  cashRequests           CashRequest[]
  accountTransactions    AccountTransaction[]

  @@index([sourceType, sourceId])
  @@index([studentId, yearMonth])
  @@index([businessEntityId])
  @@index([recordStatus])
  @@index([cashStatus])
  @@map("income_records")
}

model ExpenseRecord {
  id                String              @id @default(uuid()) @db.Uuid
  sourceType        String              @map("source_type")
  sourceId          String?             @map("source_id")
  teacherId         String?             @map("teacher_id") @db.Uuid
  businessEntityId  String?             @map("business_entity_id") @db.Uuid
  yearMonth         String?             @map("year_month") @db.VarChar(7)
  title             String
  originalCurrency  CurrencyCode        @map("original_currency")
  originalAmountJpy Int?                @map("original_amount_jpy")
  originalAmountCny Decimal?            @map("original_amount_cny") @db.Decimal(12, 2)
  recordStatus      ExpenseRecordStatus @default(pending) @map("record_status")
  cashStatus        CashRequestStatus   @default(not_requested) @map("cash_status")
  memo              String?
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  teacher             Teacher?             @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  businessEntity      BusinessEntity?      @relation(fields: [businessEntityId], references: [id], onDelete: Restrict)
  wageSnapshot        TeacherWageSnapshot? @relation("TeacherWageExpense")
  cashRequests        CashRequest[]
  accountTransactions AccountTransaction[]

  @@index([sourceType, sourceId])
  @@index([teacherId, yearMonth])
  @@index([businessEntityId])
  @@index([recordStatus])
  @@index([cashStatus])
  @@map("expense_records")
}

model CashRequest {
  id                    String               @id @default(uuid()) @db.Uuid
  direction             CashRequestDirection
  sourceType            String               @map("source_type")
  sourceId              String?              @map("source_id")
  incomeRecordId        String?              @map("income_record_id") @db.Uuid
  expenseRecordId       String?              @map("expense_record_id") @db.Uuid
  status                CashRequestStatus    @default(cash_requested)
  expectedCurrency      CurrencyCode         @map("expected_currency")
  expectedAmountJpy     Int?                 @map("expected_amount_jpy")
  expectedAmountCny     Decimal?             @map("expected_amount_cny") @db.Decimal(12, 2)
  carryoverAmountCny    Decimal?             @map("carryover_amount_cny") @db.Decimal(12, 2)
  requestedCurrency     CurrencyCode         @map("requested_currency")
  requestedAmountJpy    Int?                 @map("requested_amount_jpy")
  requestedAmountCny    Decimal?             @map("requested_amount_cny") @db.Decimal(12, 2)
  exchangeRate          Decimal?             @map("exchange_rate") @db.Decimal(18, 8)
  exchangeRateSource    String?              @map("exchange_rate_source")
  conversionMethod      String?              @map("conversion_method")
  cashAccountCode       String?              @map("cash_account_code")
  externalCashRequestId String?              @map("external_cash_request_id")
  externalCashEventId   String?              @map("external_cash_event_id")
  rejectionReason       String?              @map("rejection_reason")
  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  incomeRecord  IncomeRecord?  @relation(fields: [incomeRecordId], references: [id], onDelete: Restrict)
  expenseRecord ExpenseRecord? @relation(fields: [expenseRecordId], references: [id], onDelete: Restrict)

  @@index([direction])
  @@index([sourceType, sourceId])
  @@index([incomeRecordId])
  @@index([expenseRecordId])
  @@index([status])
  @@index([externalCashRequestId])
  @@map("cash_requests")
}

model ExternalWorkplace {
  id        String       @id @default(uuid()) @db.Uuid
  code      String       @unique
  name      String
  status    RecordStatus @default(active)
  memo      String?
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  lessons     ExternalWorkLesson[]
  settlements ExternalWorkMonthlySettlement[]

  @@index([status])
  @@map("external_workplaces")
}

model ExternalWorkLesson {
  id                   String                   @id @default(uuid()) @db.Uuid
  workplaceId          String                   @map("workplace_id") @db.Uuid
  yearMonth            String                   @map("year_month") @db.VarChar(7)
  lessonType           ExternalWorkLessonType   @map("lesson_type")
  plannedLessonId      String?                  @unique @map("planned_lesson_id") @db.Uuid
  lessonDate           DateTime                 @map("lesson_date") @db.Date
  startTime            String                   @map("start_time") @db.VarChar(5)
  endTime              String                   @map("end_time") @db.VarChar(5)
  durationHours        Decimal                  @map("duration_hours") @db.Decimal(6, 2)
  instructorName       String                   @map("instructor_name")
  lessonTitle          String?                  @map("lesson_title")
  hourlyRateJpy        Int                      @map("hourly_rate_jpy")
  transportationFeeJpy Int                      @default(0) @map("transportation_fee_jpy")
  lessonWageJpy        Int                      @map("lesson_wage_jpy")
  status               ExternalWorkLessonStatus @default(scheduled)
  content              String?
  memo                 String?
  sourceType           String                   @default("manual") @map("source_type")
  sourceId             String?                  @map("source_id")
  createdAt            DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  workplace         ExternalWorkplace              @relation(fields: [workplaceId], references: [id], onDelete: Restrict)
  plannedLesson     ExternalWorkLesson?            @relation("ExternalWorkPlannedActual", fields: [plannedLessonId], references: [id], onDelete: Restrict)
  actualLesson      ExternalWorkLesson?            @relation("ExternalWorkPlannedActual")
  settlementDetails ExternalWorkSettlementDetail[]

  @@index([workplaceId, yearMonth])
  @@index([yearMonth])
  @@index([lessonType])
  @@index([status])
  @@index([lessonDate])
  @@map("external_work_lessons")
}

model ExternalWorkMonthlySettlement {
  id                   String                       @id @default(uuid()) @db.Uuid
  workplaceId          String                       @map("workplace_id") @db.Uuid
  yearMonth            String                       @map("year_month") @db.VarChar(7)
  lessonCount          Int                          @map("lesson_count")
  totalLessonHours     Decimal                      @map("total_lesson_hours") @db.Decimal(8, 2)
  lessonWageJpy        Int                          @map("lesson_wage_jpy")
  transportationFeeJpy Int                          @default(0) @map("transportation_fee_jpy")
  adjustmentAmountJpy  Int                          @default(0) @map("adjustment_amount_jpy")
  totalAmountJpy       Int                          @map("total_amount_jpy")
  status               ExternalWorkSettlementStatus @default(locked)
  calculationSnapshot  Json                         @map("calculation_snapshot")
  incomeRecordId       String?                      @unique @map("income_record_id") @db.Uuid
  lockedAt             DateTime                     @default(now()) @map("locked_at") @db.Timestamptz(6)
  revokedAt            DateTime?                    @map("revoked_at") @db.Timestamptz(6)
  memo                 String?
  createdAt            DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(6)

  workplace    ExternalWorkplace              @relation(fields: [workplaceId], references: [id], onDelete: Restrict)
  incomeRecord IncomeRecord?                  @relation(fields: [incomeRecordId], references: [id], onDelete: Restrict)
  details      ExternalWorkSettlementDetail[]

  @@unique([workplaceId, yearMonth])
  @@index([yearMonth])
  @@index([status])
  @@map("external_work_monthly_settlements")
}

model ExternalWorkSettlementDetail {
  id                     String   @id @default(uuid()) @db.Uuid
  settlementId           String   @map("settlement_id") @db.Uuid
  actualLessonId         String   @map("actual_lesson_id") @db.Uuid
  lessonDate             DateTime @map("lesson_date") @db.Date
  startTime              String   @map("start_time") @db.VarChar(5)
  endTime                String   @map("end_time") @db.VarChar(5)
  durationHours          Decimal  @map("duration_hours") @db.Decimal(6, 2)
  instructorNameSnapshot String   @map("instructor_name_snapshot")
  lessonTitleSnapshot    String?  @map("lesson_title_snapshot")
  hourlyRateJpy          Int      @map("hourly_rate_jpy")
  lessonWageJpy          Int      @map("lesson_wage_jpy")
  transportationFeeJpy   Int      @map("transportation_fee_jpy")
  contentSnapshot        String?  @map("content_snapshot")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  settlement   ExternalWorkMonthlySettlement @relation(fields: [settlementId], references: [id], onDelete: Restrict)
  actualLesson ExternalWorkLesson            @relation(fields: [actualLessonId], references: [id], onDelete: Restrict)

  @@unique([settlementId, actualLessonId])
  @@index([actualLessonId])
  @@map("external_work_settlement_details")
}

model AuditEvent {
  id             String         @id @default(uuid()) @db.Uuid
  actorUserId    String?        @map("actor_user_id") @db.Uuid
  action         String
  targetType     String         @map("target_type")
  targetId       String?        @map("target_id")
  riskLevel      AuditRiskLevel @default(low) @map("risk_level")
  reason         String?
  beforeSnapshot Json?          @map("before_snapshot")
  afterSnapshot  Json?          @map("after_snapshot")
  metadata       Json?
  requestId      String?        @map("request_id")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  actorUser User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([riskLevel])
  @@index([createdAt])
  @@map("audit_events")
}
