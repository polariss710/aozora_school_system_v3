  syncStatus               LegacyIncomeLinkageStatus @map("sync_status")
  attemptNo                Int                       @map("attempt_no")
  cashRequestId            String?                   @map("cash_request_id") @db.Uuid
  cashRequestStatus        String?                   @map("cash_request_status")
  requestedAt              DateTime?                 @map("requested_at") @db.Timestamptz(6)
  confirmedAt              DateTime?                 @map("confirmed_at") @db.Timestamptz(6)
  rejectedAt               DateTime?                 @map("rejected_at") @db.Timestamptz(6)
  rejectedReason           String?                   @map("rejected_reason")
  cashRequestLastCheckedAt DateTime?                 @map("cash_request_last_checked_at") @db.Timestamptz(6)
  retryCount               Int                       @map("retry_count")
  lastError                String?                   @map("last_error")
  note                     String?
  sourceSnapshot           Json                      @map("source_snapshot")
  sourceCreatedAt          DateTime                  @map("source_created_at") @db.Timestamptz(6)
  sourceUpdatedAt          DateTime                  @map("source_updated_at") @db.Timestamptz(6)
  sourceSyncedAt           DateTime?                 @map("source_synced_at") @db.Timestamptz(6)
  migratedAt               DateTime                  @default(now()) @map("migrated_at") @db.Timestamptz(6)

  importBatch  HistoricalExternalWorkImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: Restrict)
  incomeRecord IncomeRecord                       @relation(fields: [incomeRecordId], references: [id], onDelete: Restrict)

  @@unique([sourceTable, sourceId, sourceEventType, attemptNo])
  @@index([incomeRecordId])
  @@index([cashTransactionId])
  @@index([syncStatus])
  @@map("legacy_income_linkage_events")
}

model AuditEvent {
  id             String         @id @default(uuid()) @db.Uuid
  actorUserId    String?        @map("actor_user_id") @db.Uuid
  action         String
  targetType     String         @map("target_type")
  targetId       String?        @map("target_id")
  riskLevel      AuditRiskLevel @default(low) @map("risk_level")
  reason         String?
  beforeSnapshot Json?          @map("before_snapshot")
  afterSnapshot  Json?          @map("after_snapshot")
  metadata       Json?
  requestId      String?        @map("request_id")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  actorUser User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([riskLevel])
  @@index([createdAt])
  @@map("audit_events")
}
