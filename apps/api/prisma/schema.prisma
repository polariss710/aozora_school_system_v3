generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RecordStatus {
  active
  inactive
  archived
}

enum UserStatus {
  active
  suspended
  inactive
}

enum AccountType {
  corporate
  advance
}

enum CurrencyCode {
  JPY
  CNY
}

enum AuditRiskLevel {
  low
  medium
  high
  critical
}

enum PlannedLessonStatus {
  scheduled
  actual_created
  makeup_pending
  makeup_completed
  cancelled
}

enum ActualLessonStatus {
  completed
  cancelled
}

enum TuitionBillStatus {
  generated
  income_created
  voided
  superseded
}

enum IncomeRecordStatus {
  pending
  voided
  cash_confirmed
  historical_confirmed
}

enum ExpenseRecordStatus {
  pending
  voided
  cash_confirmed
  historical_confirmed
}

enum CashRequestStatus {
  not_requested
  cash_requested
  cash_withdrawn
  cash_rejected
  cash_confirmed
  account_transaction_created
  needs_manual_review
}

enum CashRequestDirection {
  income
  expense
}

enum AccountTransactionDirection {
  in
  out
}

enum AccountTransactionStatus {
  active
  reversed
}

enum AccountTransferStatus {
  completed
  voided
}

enum ReimbursementStatus {
  completed
  voided
}

enum CashInboundEventStatus {
  account_transaction_created
  rejected
}

enum ExternalWorkLessonType {
  planned
  actual
}

enum ExternalWorkLessonStatus {
  scheduled
  actual_created
  completed
  cancelled
}

enum ExternalWorkSettlementStatus {
  locked
  income_created
  revoked
}

enum MigrationRecordDisposition {
  migrated
  audit_only
  skipped
}

enum LegacyIncomeLinkageStatus {
  pending
  pending_cash_request
  awaiting_cash_confirmation
  synced
  historical_confirmed
  cash_rejected
  failed
  blocked
}

enum StudentSettlementStatus {
  locked
  revoked
}

enum TeacherWageSnapshotStatus {
  locked
  adjustment_confirmed
  expense_created
  revoked
}

enum TeacherWageAdjustmentStatus {
  none
  exported
  imported
  manual_adjusted
  confirmed
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  displayName  String     @map("display_name")
  status       UserStatus @default(active)
  passwordHash String?    @map("password_hash")
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz(6)
  memo         String?
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  userRoles            UserRole[]
  auditEvents          AuditEvent[]    @relation("AuditActor")
  issuedReceiptRecords ReceiptRecord[] @relation("ReceiptIssuer")

  @@index([status])
  @@map("users")
}

model Role {
  id          String       @id @default(uuid()) @db.Uuid
  code        String       @unique
  name        String
  description String?
  status      RecordStatus @default(active)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([status])
  @@map("roles")
}

model Permission {
  id          String       @id @default(uuid()) @db.Uuid
  code        String       @unique
  name        String
  description String?
  status      RecordStatus @default(active)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@index([status])
  @@map("permissions")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model BusinessEntity {
  id          String       @id @default(uuid()) @db.Uuid
  code        String       @unique
  name        String
  status      RecordStatus @default(active)
  memo        String?
  legacyTable String?      @map("legacy_table")
  legacyId    String?      @map("legacy_id")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  students       Student[]
  plannedLessons StudentPlannedLesson[]
  actualLessons  StudentActualLesson[]
  incomeRecords  IncomeRecord[]
  expenseRecords ExpenseRecord[]
  wageRules      TeacherWageRule[]
  wageSnapshots  TeacherWageSnapshot[]

  @@unique([legacyTable, legacyId])
  @@index([status])
  @@map("business_entities")
}

model Account {
  id        String       @id @default(uuid()) @db.Uuid
  code      String       @unique
  name      String
  type      AccountType
  currency  CurrencyCode
  status    RecordStatus @default(active)
  memo      String?
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  transactions                  AccountTransaction[]
  corporateReimbursementRecords ReimbursementRecord[] @relation("CorporateReimbursementAccount")
  advanceReimbursementRecords   ReimbursementRecord[] @relation("AdvanceReimbursementAccount")
  cashInboundEvents             CashInboundEvent[]    @relation("CashInboundCorporateAccount")
  outgoingTransfers             AccountTransfer[]     @relation("AccountTransferFromAccount")
  incomingTransfers             AccountTransfer[]     @relation("AccountTransferToAccount")

  @@index([status])
  @@index([type])
  @@map("accounts")
}

model AccountTransaction {
  id              String                      @id @default(uuid()) @db.Uuid
  accountId       String                      @map("account_id") @db.Uuid
  direction       AccountTransactionDirection
  sourceType      String                      @map("source_type")
  sourceId        String?                     @map("source_id")
  incomeRecordId  String?                     @map("income_record_id") @db.Uuid
  expenseRecordId String?                     @map("expense_record_id") @db.Uuid
  transactionDate DateTime                    @map("transaction_date") @db.Date
  title           String
  currency        CurrencyCode
  amountJpy       Int?                        @map("amount_jpy")
  amountCny       Decimal?                    @map("amount_cny") @db.Decimal(12, 2)
  status          AccountTransactionStatus    @default(active)
  idempotencyKey  String?                     @unique @map("idempotency_key")
  externalEventId String?                     @map("external_event_id")
  memo            String?
  reversedAt      DateTime?                   @map("reversed_at") @db.Timestamptz(6)
  createdAt       DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)

  account                Account              @relation(fields: [accountId], references: [id], onDelete: Restrict)
  incomeRecord           IncomeRecord?        @relation(fields: [incomeRecordId], references: [id], onDelete: Restrict)
  expenseRecord          ExpenseRecord?       @relation(fields: [expenseRecordId], references: [id], onDelete: Restrict)
  reimbursementCorporate ReimbursementRecord? @relation("ReimbursementCorporateTransaction")
  reimbursementAdvance   ReimbursementRecord? @relation("ReimbursementAdvanceTransaction")
  cashInboundEvent       CashInboundEvent?    @relation("CashInboundAccountTransaction")
  outgoingTransfer       AccountTransfer?     @relation("AccountTransferFromTransaction")
  incomingTransfer       AccountTransfer?     @relation("AccountTransferToTransaction")

  @@index([accountId, transactionDate])
  @@index([direction])
  @@index([sourceType, sourceId])
  @@index([incomeRecordId])
  @@index([expenseRecordId])
  @@index([status])
  @@map("account_transactions")
}

model AccountTransfer {
  id                String                @id @default(uuid()) @db.Uuid
  fromAccountId     String                @map("from_account_id") @db.Uuid
  toAccountId       String                @map("to_account_id") @db.Uuid
  fromTransactionId String                @unique @map("from_transaction_id") @db.Uuid
  toTransactionId   String                @unique @map("to_transaction_id") @db.Uuid
  transferDate      DateTime              @map("transfer_date") @db.Date
  currency          CurrencyCode
  amountJpy         Int?                  @map("amount_jpy")
  amountCny         Decimal?              @map("amount_cny") @db.Decimal(12, 2)
  status            AccountTransferStatus @default(completed)
  memo              String?
  voidedAt          DateTime?             @map("voided_at") @db.Timestamptz(6)
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  fromAccount     Account            @relation("AccountTransferFromAccount", fields: [fromAccountId], references: [id], onDelete: Restrict)
  toAccount       Account            @relation("AccountTransferToAccount", fields: [toAccountId], references: [id], onDelete: Restrict)
  fromTransaction AccountTransaction @relation("AccountTransferFromTransaction", fields: [fromTransactionId], references: [id], onDelete: Restrict)
  toTransaction   AccountTransaction @relation("AccountTransferToTransaction", fields: [toTransactionId], references: [id], onDelete: Restrict)

  @@index([transferDate])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([status])
  @@map("account_transfers")
}

model ReimbursementRecord {
  id                     String              @id @default(uuid()) @db.Uuid
  expenseRecordId        String              @unique @map("expense_record_id") @db.Uuid
  corporateAccountId     String              @map("corporate_account_id") @db.Uuid
  advanceAccountId       String              @map("advance_account_id") @db.Uuid
  corporateTransactionId String              @unique @map("corporate_transaction_id") @db.Uuid
  advanceTransactionId   String              @unique @map("advance_transaction_id") @db.Uuid
  reimbursementDate      DateTime            @map("reimbursement_date") @db.Date
  currency               CurrencyCode
  amountJpy              Int?                @map("amount_jpy")
  amountCny              Decimal?            @map("amount_cny") @db.Decimal(12, 2)
  status                 ReimbursementStatus @default(completed)
  memo                   String?
  voidedAt               DateTime?           @map("voided_at") @db.Timestamptz(6)
  createdAt              DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  expenseRecord        ExpenseRecord      @relation(fields: [expenseRecordId], references: [id], onDelete: Restrict)
  corporateAccount     Account            @relation("CorporateReimbursementAccount", fields: [corporateAccountId], references: [id], onDelete: Restrict)
  advanceAccount       Account            @relation("AdvanceReimbursementAccount", fields: [advanceAccountId], references: [id], onDelete: Restrict)
  corporateTransaction AccountTransaction @relation("ReimbursementCorporateTransaction", fields: [corporateTransactionId], references: [id], onDelete: Restrict)
  advanceTransaction   AccountTransaction @relation("ReimbursementAdvanceTransaction", fields: [advanceTransactionId], references: [id], onDelete: Restrict)

  @@index([reimbursementDate])
  @@index([corporateAccountId])
  @@index([advanceAccountId])
  @@index([status])
  @@map("reimbursement_records")
}

model CashInboundEvent {
  id                    String                 @id @default(uuid()) @db.Uuid
  externalCashEventId   String                 @unique @map("external_cash_event_id")
  eventType             String                 @default("cash_to_school_corporate_deposit") @map("event_type")
  corporateAccountId    String                 @map("corporate_account_id") @db.Uuid
  accountTransactionId  String                 @unique @map("account_transaction_id") @db.Uuid
  eventDate             DateTime               @map("event_date") @db.Date
  sourceCurrency        CurrencyCode?          @map("source_currency")
  sourceAmountJpy       Int?                   @map("source_amount_jpy")
  sourceAmountCny       Decimal?               @map("source_amount_cny") @db.Decimal(12, 2)
  targetCurrency        CurrencyCode           @map("target_currency")
  targetAmountJpy       Int?                   @map("target_amount_jpy")
  targetAmountCny       Decimal?               @map("target_amount_cny") @db.Decimal(12, 2)
  exchangeRate          Decimal?               @map("exchange_rate") @db.Decimal(18, 8)
  feeCurrency           CurrencyCode?          @map("fee_currency")
  feeAmountJpy          Int?                   @map("fee_amount_jpy")
  feeAmountCny          Decimal?               @map("fee_amount_cny") @db.Decimal(12, 2)
  linkedIncomeRecordIds String[]               @default([]) @map("linked_income_record_ids")
  status                CashInboundEventStatus @default(account_transaction_created)
  memo                  String?
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  corporateAccount   Account            @relation("CashInboundCorporateAccount", fields: [corporateAccountId], references: [id], onDelete: Restrict)
  accountTransaction AccountTransaction @relation("CashInboundAccountTransaction", fields: [accountTransactionId], references: [id], onDelete: Restrict)

  @@index([eventDate])
  @@index([eventType])
  @@index([corporateAccountId])
  @@index([status])
  @@map("cash_inbound_events")
}

model Student {
  id                      String       @id @default(uuid()) @db.Uuid
  code                    String?      @unique
  name                    String
  kanaName                String?      @map("kana_name")
  status                  RecordStatus @default(active)
  primaryBusinessEntityId String?      @map("primary_business_entity_id") @db.Uuid
  memo                    String?
  legacyTable             String?      @map("legacy_table")
  legacyId                String?      @map("legacy_id")
  createdAt               DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  primaryBusinessEntity BusinessEntity?            @relation(fields: [primaryBusinessEntityId], references: [id], onDelete: Restrict)
  plannedLessons        StudentPlannedLesson[]
  actualLessons         StudentActualLesson[]
  tuitionBills          StudentTuitionBill[]
  monthlySettlements    StudentMonthlySettlement[]
  incomeRecords         IncomeRecord[]

  @@index([status])
  @@index([primaryBusinessEntityId])
  @@map("students")
}

model Teacher {
  id          String       @id @default(uuid()) @db.Uuid
  code        String?      @unique
  name        String
  kanaName    String?      @map("kana_name")
  status      RecordStatus @default(active)
  memo        String?
  legacyTable String?      @map("legacy_table")
  legacyId    String?      @map("legacy_id")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  plannedLessons StudentPlannedLesson[]
  actualLessons  StudentActualLesson[]
  wageRules      TeacherWageRule[]
  wageSnapshots  TeacherWageSnapshot[]
  expenseRecords ExpenseRecord[]

  @@index([status])
  @@map("teachers")
}

model Subject {
  id          String       @id @default(uuid()) @db.Uuid
  code        String       @unique
  name        String
  category    String?
  sortOrder   Int          @default(0) @map("sort_order")
  status      RecordStatus @default(active)
  memo        String?
  legacyTable String?      @map("legacy_table")
  legacyId    String?      @map("legacy_id")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  plannedLessons StudentPlannedLesson[]
  actualLessons  StudentActualLesson[]

  @@unique([legacyTable, legacyId])
  @@index([status])
  @@index([sortOrder])
  @@map("subjects")
}

model StudentPlannedLesson {
  id               String              @id @default(uuid()) @db.Uuid
  studentId        String              @map("student_id") @db.Uuid
  teacherId        String              @map("teacher_id") @db.Uuid
  subjectId        String              @map("subject_id") @db.Uuid
  businessEntityId String              @map("business_entity_id") @db.Uuid
  yearMonth        String              @map("year_month") @db.VarChar(7)
  weekAnchorDate   DateTime            @map("week_anchor_date") @db.Date
  lessonNo         Int?                @map("lesson_no")
  plannedStartTime String?             @map("planned_start_time") @db.VarChar(5)
  plannedEndTime   String?             @map("planned_end_time") @db.VarChar(5)
  durationHours    Decimal             @map("duration_hours") @db.Decimal(6, 2)
  plannedFeeJpy    Int                 @map("planned_fee_jpy")
  content          String?
  memo             String?
  status           PlannedLessonStatus @default(scheduled)
  sourceType       String              @default("manual") @map("source_type")
  sourceId         String?             @map("source_id")
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  student        Student              @relation(fields: [studentId], references: [id], onDelete: Restrict)
  teacher        Teacher              @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  subject        Subject              @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  businessEntity BusinessEntity       @relation(fields: [businessEntityId], references: [id], onDelete: Restrict)
  actualLesson   StudentActualLesson?

  @@index([yearMonth])
  @@index([studentId, yearMonth])
  @@index([teacherId, yearMonth])
  @@index([subjectId])
  @@index([businessEntityId])
  @@index([status])
  @@index([weekAnchorDate])
  @@map("student_planned_lessons")
}

model StudentActualLesson {
  id                  String             @id @default(uuid()) @db.Uuid
  plannedLessonId     String?            @unique @map("planned_lesson_id") @db.Uuid
  studentId           String             @map("student_id") @db.Uuid
  teacherId           String             @map("teacher_id") @db.Uuid
  subjectId           String             @map("subject_id") @db.Uuid
  businessEntityId    String             @map("business_entity_id") @db.Uuid
  yearMonth           String             @map("year_month") @db.VarChar(7)
  actualDate          DateTime           @map("actual_date") @db.Date
  startTime           String?            @map("start_time") @db.VarChar(5)
  endTime             String?            @map("end_time") @db.VarChar(5)
  durationHours       Decimal            @map("duration_hours") @db.Decimal(6, 2)
  content             String?
  memo                String?
  status              ActualLessonStatus @default(completed)
  teacherWageEligible Boolean            @default(true) @map("teacher_wage_eligible")
  sourceType          String             @default("planned_lesson") @map("source_type")
  sourceId            String?            @map("source_id")
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  plannedLesson  StudentPlannedLesson?       @relation(fields: [plannedLessonId], references: [id], onDelete: Restrict)
  student        Student                     @relation(fields: [studentId], references: [id], onDelete: Restrict)
  teacher        Teacher                     @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  subject        Subject                     @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  businessEntity BusinessEntity              @relation(fields: [businessEntityId], references: [id], onDelete: Restrict)
  wageDetails    TeacherWageSnapshotDetail[]

  @@index([yearMonth])
  @@index([studentId, yearMonth])
  @@index([teacherId, yearMonth])
  @@index([subjectId])
  @@index([businessEntityId])
  @@index([status])
  @@index([actualDate])
  @@map("student_actual_lessons")
}

model StudentTuitionBill {
  id                  String            @id @default(uuid()) @db.Uuid
  studentId           String            @map("student_id") @db.Uuid
  yearMonth           String            @map("year_month") @db.VarChar(7)
  version             Int               @default(1)
  plannedLessonCount  Int               @map("planned_lesson_count")
  plannedAmountJpy    Int               @map("planned_amount_jpy")
  carryoverAmountCny  Decimal           @default(0) @map("carryover_amount_cny") @db.Decimal(12, 2)
  status              TuitionBillStatus @default(generated)
  calculationSnapshot Json              @map("calculation_snapshot")
  incomeRecordId      String?           @unique @map("income_record_id") @db.Uuid
  replacesId          String?           @map("replaces_id") @db.Uuid
  generatedAt         DateTime          @default(now()) @map("generated_at") @db.Timestamptz(6)
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  student      Student              @relation(fields: [studentId], references: [id], onDelete: Restrict)
  incomeRecord IncomeRecord?        @relation(fields: [incomeRecordId], references: [id], onDelete: Restrict)
  replaces     StudentTuitionBill?  @relation("TuitionBillRevisions", fields: [replacesId], references: [id], onDelete: Restrict)
  replacements StudentTuitionBill[] @relation("TuitionBillRevisions")

  @@unique([studentId, yearMonth, version])
  @@index([studentId, yearMonth, status])
  @@index([replacesId])
  @@index([yearMonth])
  @@index([status])
  @@map("student_tuition_bills")
}

model StudentMonthlySettlement {
  id                         String                  @id @default(uuid()) @db.Uuid
  studentId                  String                  @map("student_id") @db.Uuid
  yearMonth                  String                  @map("year_month") @db.VarChar(7)
  plannedLessonCount         Int                     @map("planned_lesson_count")
  billableLessonCount        Int                     @map("billable_lesson_count")
  cancelledLessonCount       Int                     @map("cancelled_lesson_count")
  actualLessonCount          Int                     @map("actual_lesson_count")
  plannedAmountJpy           Int                     @map("planned_amount_jpy")
  billableAmountJpy          Int                     @map("billable_amount_jpy")
  receivedAmountJpy          Int                     @default(0) @map("received_amount_jpy")
  receivedAmountCny          Decimal                 @default(0) @map("received_amount_cny") @db.Decimal(12, 2)
  previousCarryoverAmountCny Decimal                 @default(0) @map("previous_carryover_amount_cny") @db.Decimal(12, 2)
  settlementExchangeRate     Decimal?                @map("settlement_exchange_rate") @db.Decimal(18, 8)
  adjustmentAmountCny        Decimal                 @default(0) @map("adjustment_amount_cny") @db.Decimal(12, 2)
  carryoverAmountCny         Decimal                 @default(0) @map("carryover_amount_cny") @db.Decimal(12, 2)
  status                     StudentSettlementStatus @default(locked)
  calculationSnapshot        Json                    @map("calculation_snapshot")
  lockedAt                   DateTime                @default(now()) @map("locked_at") @db.Timestamptz(6)
  revokedAt                  DateTime?               @map("revoked_at") @db.Timestamptz(6)
  memo                       String?
  createdAt                  DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  student Student @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@unique([studentId, yearMonth])
  @@index([yearMonth])
  @@index([status])
  @@map("student_monthly_settlements")
}

model TeacherWageRule {
  id               String       @id @default(uuid()) @db.Uuid
  teacherId        String       @map("teacher_id") @db.Uuid
  businessEntityId String       @map("business_entity_id") @db.Uuid
  hourlyRateJpy    Int          @map("hourly_rate_jpy")
  status           RecordStatus @default(active)
  memo             String?
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  teacher        Teacher        @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  businessEntity BusinessEntity @relation(fields: [businessEntityId], references: [id], onDelete: Restrict)

  @@unique([teacherId, businessEntityId])
  @@index([teacherId])
  @@index([businessEntityId])
  @@index([status])
  @@map("teacher_wage_rules")
}

model TeacherWageSnapshot {
  id                   String                      @id @default(uuid()) @db.Uuid
  teacherId            String                      @map("teacher_id") @db.Uuid
